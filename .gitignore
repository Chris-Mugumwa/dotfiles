# └──────────────────────────────────────────────────────────────────────────────┘
dconf/
pulse/
session/
systemd/

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Cache & Generated Files                                                      │
# └──────────────────────────────────────────────────────────────────────────────┘
**/Cache/
**/cache/
**/CachedData/
**/CachedExtensionVSIXs/
**/Code Cache/
**/GPUCache/
**/DawnGraphiteCache/
**/DawnWebGPUCache/
**/Crashpad/
**/*.log
**/*.tmp
**/blob_storage/

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Sensitive Data                                                               │
# └──────────────────────────────────────────────────────────────────────────────┘
**/Cookies
**/Cookies-journal
**/*credentials*
**/*tokens*
**/*secret*
**/Login Data
**/Login Data-journal
**/*.pem
**/*.key
**/DIPS
**/DIPS-wal

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Browser Data                                                                 │
# └──────────────────────────────────────────────────────────────────────────────┘
mozilla/
firefox/
browsers/
chromium/
google-chrome/

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Nested Git Repos (reinstallable via plugin managers)                        │
# └──────────────────────────────────────────────────────────────────────────────┘
# Tmux plugins - reinstall with: prefix + I (via tpm)
tmux/plugins/

# Spicetify themes with their own repos
spicetify/Themes/*/

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Misc App Data                                                                │
# └──────────────────────────────────────────────────────────────────────────────┘
act/
htop/
