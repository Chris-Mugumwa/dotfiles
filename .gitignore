Blackmagic Design/
Android Open Source Project/

# RC files that change frequently
baloofileinformationrc
dolphinrc
mimeapps.list
pavucontrol.ini

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Fish shell generated files                                                   │
# └──────────────────────────────────────────────────────────────────────────────┘
fish/fish_variables
fish/completions/
fish/generated_completions/

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ OBS (keep config, ignore recordings/profiles cache)                          │
# └──────────────────────────────────────────────────────────────────────────────┘
obs-studio/logs/
obs-studio/crashes/
obs-studio/plugin_config/
obs-studio/profiler_data/

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ Zen Browser (Firefox fork) — profile is not rice, contains credentials      │
# └──────────────────────────────────────────────────────────────────────────────┘
zen/*
!zen/jsrzrdtb.Default (release)/
zen/jsrzrdtb.Default (release)/*
!zen/jsrzrdtb.Default (release)/chrome/

# ┌──────────────────────────────────────────────────────────────────────────────┐
# │ VS Code / Code-OSS — ignore app state, keep user rice                       │
# └──────────────────────────────────────────────────────────────────────────────┘
Code - OSS/*
!Code - OSS/User/
Code - OSS/User/*
!Code - OSS/User/settings.json
!Code - OSS/User/keybindings.json
!Code - OSS/User/snippets/
